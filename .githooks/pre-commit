#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Git hooks inherit repo-scoped env vars that can break nested git commands.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_PREFIX GIT_COMMON_DIR

echo "pre-commit: running make format-check"
make format-check
echo "pre-commit: running make lint"
make lint
