digraph dependencies {
  rankdir=LR;
  node [shape=box];

  "/project/main.dart" [label="main.dart", style=filled, fillcolor=white];
  "/project/main.go" [label="main.go", style=filled, fillcolor=lightyellow];
  "/project/utils.dart" [label="utils.dart", style=filled, fillcolor=white];
  "/project/utils.go" [label="utils.go", style=filled, fillcolor=lightyellow];
}