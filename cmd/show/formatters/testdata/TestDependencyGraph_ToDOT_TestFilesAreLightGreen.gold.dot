digraph dependencies {
  rankdir=LR;
  node [shape=box];

  "/project/main.go" [label="main.go", style=filled, fillcolor=white];
  "/project/main_test.go" [label="main_test.go", style=filled, fillcolor=lightgreen];
  "/project/utils.go" [label="utils.go", style=filled, fillcolor=white];
  "/project/utils_test.go" [label="utils_test.go", style=filled, fillcolor=lightgreen];

  "/project/main.go" -> "/project/utils.go";
  "/project/main_test.go" -> "/project/main.go";
  "/project/utils_test.go" -> "/project/utils.go";
}