digraph dependencies {
  rankdir=LR;
  node [shape=box];

  "/project/config.go" [label="config.go", style=filled, fillcolor=white];
  "/project/helpers.go" [label="helpers.go", style=filled, fillcolor=white];
  "/project/main.dart" [label="main.dart", style=filled, fillcolor=lightblue];
  "/project/main.go" [label="main.go", style=filled, fillcolor=white];
  "/project/output_format.go" [label="output_format.go", style=filled, fillcolor=white];
  "/project/utils.dart" [label="utils.dart", style=filled, fillcolor=lightblue];
  "/project/utils.go" [label="utils.go", style=filled, fillcolor=white];

  "/project/main.go" -> "/project/utils.go";
}